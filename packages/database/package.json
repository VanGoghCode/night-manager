{
  "name": "@night-manager/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "dependencies": {
    "@night-manager/config": "workspace:*",
    "@night-manager/role-loader": "workspace:*",
    "@prisma/client": "6.19.2",
    "bcryptjs": "^3.0.3",
    "zod": "^4.1.11"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:generate": "prisma generate --config prisma.config.ts",
    "db:migrate": "prisma migrate dev --config prisma.config.ts",
    "db:deploy": "prisma migrate deploy --config prisma.config.ts",
    "db:seed": "tsx prisma/seed.ts",
    "roles:sync": "tsx src/sync-role-markdown.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "node -e \"console.log('database: no tests yet')\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prisma": "6.19.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
